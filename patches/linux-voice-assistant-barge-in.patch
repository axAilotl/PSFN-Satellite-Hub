+
+        if rms < threshold:
+            self._clear_barge_in()
+            return
+
+        if not self._barge_in_ducked:
+            _LOGGER.debug("Barge-in speech detected; ducking TTS (rms=%.3f)", rms)
+            self.state.tts_player.duck(duck_factor)
+            self._barge_in_ducked = True
+
+        self._barge_in_chunks += 1
+        if self._barge_in_chunks < hold_chunks:
+            return
+
+        _LOGGER.info("Barge-in interrupt triggered (rms=%.3f, chunks=%s)", rms, self._barge_in_chunks)
+        self._clear_barge_in()
