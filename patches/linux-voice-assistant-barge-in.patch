+            self._barge_in_ducked = False
+
+    def handle_barge_in_signal(
+        self,
+        rms: float,
+        *,
+        threshold: float,
+        hold_chunks: int,
+        duck_factor: float,
+    ) -> None:
+        if self.state.muted or self._is_streaming_audio or (not self._pipeline_active) or (not self.state.tts_player.is_playing):
+            self._clear_barge_in()
